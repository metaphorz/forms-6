#!/bin/zsh
# Stop the Form S-6 grid viewer server.
cd "$(dirname "$0")"
if [[ -f tests/auto/server.pid ]]; then
  PID=$(cat tests/auto/server.pid)
  if kill "$PID" 2>/dev/null; then echo "Stopped server PID $PID"; else echo "No live process $PID"; fi
  rm -f tests/auto/server.pid
else
  echo "No server.pid found"
fi
